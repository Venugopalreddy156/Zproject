bookshop/
 ├── app/
 ├── db/
 │    ├── schema.cds
 │    └── data/
 │         ├── sap.capire.bookshop-Books.csv
 │         └── sap.capire.bookshop-Authors.csv
 ├── srv/
 │    ├── catalog-service.cds
 │    └── catalog-service.js
 ├── package.json
 └── README.md

Db/schema.cds(Data Model)
cds
namespace sap.capire.bookshop;

entity Authors {
  key ID   : Integer;
  name     : String;
}

entity Books {
  key ID     : Integer;
  title      : String;
  stock      : Integer;
  author     : Association to Authors;
}
db/data/*.csv (Sample Data)
Authors
ID,name
1,J.K. Rowling
2,George Orwell
Books
ID,title,stock,author_ID
1,Harry Potter,100,1
2,1984,50,2
srv/catalog-service.cds (Service Layer)
using { sap.capire.bookshop as db } from '../db/schema';

service CatalogService {
  entity Books as projection on db.Books;
  entity Authors as projection on db.Authors;
}
srv/catalog-service.js (Custom Logic)
module.exports = (srv) => {
  srv.before('CREATE', 'Books', (req) => {
    if (req.data.stock < 0) {
      req.error('Stock cannot be negative');
    }
  });
};
